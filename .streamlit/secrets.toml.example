# Copy this file to .streamlit/secrets.toml for local development.
# In Streamlit Community Cloud, add the same value under App settings → Secrets.
COPILOT_TOKEN = "replace-with-your-token"
GEMINI_API_KEY = "replace-with-your-gemini-key"

# Optional YouTube upload integration.
YOUTUBE_CLIENT_ID = "replace-with-your-client-id.apps.googleusercontent.com"
YOUTUBE_CLIENT_SECRET = "replace-with-your-client-secret"
YOUTUBE_REDIRECT_URI = "https://your-app.streamlit.app/"
YOUTUBE_TOKEN_ENCRYPTION_KEY = "replace-with-a-long-random-secret"
