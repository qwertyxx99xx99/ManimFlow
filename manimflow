#!/usr/bin/env python3

import sys, os, subprocess, pathlib, tempfile, time, re, json

R = "\033[31m"; G = "\033[32m"; Y = "\033[33m"; B = "\033[34m"; RESET = "\033[0m"
def info(msg):  print(f"{B}[manimflow]{RESET} {msg}", flush=True)
def ok(msg):    print(f"{G}[manimflow]{RESET} {msg}", flush=True)
def warn(msg):  print(f"{Y}[manimflow]{RESET} {msg}", flush=True)
def err(msg):   print(f"{R}[manimflow]{RESET} {msg}", flush=True)

def check_deps():
    if subprocess.run(["which", "colab"], capture_output=True).returncode != 0:
        err("colab CLI not found.")
        print("  Install: pip install colab-cli")
        sys.exit(1)
    out = subprocess.run(["colab", "sessions"], capture_output=True, text=True)
    if "not logged in" in (out.stdout + out.stderr).lower() or out.returncode == 2:
        err("Not logged in to Colab.")
        print("  Run: colab login")
        sys.exit(1)

check_deps()

if len(sys.argv) < 2:
    print("Usage: manimflow \"your video prompt\"")
    sys.exit(1)

PROMPT = " ".join(sys.argv[1:])
OUTPUT_DIR = pathlib.Path.home() / "ManimFlow_videos"
OUTPUT_DIR.mkdir(exist_ok=True)

def run(cmd, capture=False, **kw):
    if capture:
        r = subprocess.run(cmd, capture_output=True, text=True, **kw)
        return r.stdout + r.stderr, r.returncode
    return subprocess.run(cmd, **kw).returncode

def kill_all_sessions():
    warn("Killing all existing Colab sessions...")
    out, _ = run(["colab", "sessions"], capture=True)
    for m in re.finditer(r"\[([a-f0-9]{6})\]", out):
        name = m.group(1)
        run(["colab", "stop", "-s", name], capture=True)
        info(f"  killed {name}")
    time.sleep(3)

def new_session():
    info("Creating Colab session (T4 GPU)...")
    out, rc = run(["colab", "new", "--gpu", "T4"], capture=True)
    m = re.search(r"Creating session '([a-f0-9]+)'", out)
    if rc != 0:
        if "TooManyAssignments" in out or "Precondition" in out:
            return None
        err(out)
        sys.exit(1)
    if m:
        return m.group(1)
    err(f"Could not parse session ID from: {out}")
    sys.exit(1)

def get_session():
    session = new_session()
    if session is None:
        kill_all_sessions()
        session = new_session()
        if session is None:
            err("Could not create session even after killing all")
            sys.exit(1)
    return session

