#!/usr/bin/env python3

import os
import pathlib
import re
import subprocess
import sys
import tempfile
import time


R = "\033[31m"; G = "\033[32m"; Y = "\033[33m"; B = "\033[34m"; RESET = "\033[0m"
def info(message): print(f"{B}[manimflow]{RESET} {message}", flush=True)
def ok(message): print(f"{G}[manimflow]{RESET} {message}", flush=True)
def warn(message): print(f"{Y}[manimflow]{RESET} {message}", flush=True)
def err(message): print(f"{R}[manimflow]{RESET} {message}", flush=True)


def run(command, capture=False, **kwargs):
    if capture:
        result = subprocess.run(command, capture_output=True, text=True, **kwargs)
        return result.stdout + result.stderr, result.returncode
    return subprocess.run(command, **kwargs).returncode


def check_dependencies():
    if not shutil_which("colab"):
        err("colab CLI not found. Install it with: pip install colab-cli")
        raise SystemExit(1)
    output, code = run(["colab", "sessions"], capture=True)
    if "not logged in" in output.lower() or code == 2:
        err("Not logged in to Colab. Run: colab login")
        raise SystemExit(1)


def shutil_which(command):
    from shutil import which
    return which(command)


def stop_existing_sessions():
    warn("Stopping existing Colab sessions...")
    output, _ = run(["colab", "sessions"], capture=True)
    for match in re.finditer(r"\[([a-f0-9]{6})\]", output):
        run(["colab", "stop", "-s", match.group(1)], capture=True)
    time.sleep(3)


def create_session():
    output, code = run(["colab", "new", "--gpu", "T4"], capture=True)
    match = re.search(r"Creating session '([a-f0-9]+)'", output)
    if code == 0 and match:
        return match.group(1)
    if "TooManyAssignments" in output or "Precondition" in output:
        return None
    err(output)
    raise SystemExit(1)


def get_session():
    session = create_session()
    if session:
        return session
    stop_existing_sessions()
    session = create_session()
    if not session:
        err("Could not create a Colab session.")
        raise SystemExit(1)
    return session


check_dependencies()
if len(sys.argv) < 2:
    print('Usage: manimflow "your video prompt"')
    raise SystemExit(1)

prompt = " ".join(sys.argv[1:])
output_dir = pathlib.Path.home() / "ManimFlow_videos"
output_dir.mkdir(exist_ok=True)
slug = re.sub(r"[^a-zA-Z0-9]+", "_", prompt[:50]).strip("_") or "animation"
output_path = output_dir / f"{slug}.mp4"

worker = f'''
import pathlib, shutil, subprocess, sys, threading, time, urllib.request

def keepalive():
    while True:
        time.sleep(25)
        try:
            urllib.request.urlopen("http://172.28.0.1:9000/api/kernels", timeout=5)
        except Exception:
            pass
threading.Thread(target=keepalive, daemon=True).start()

print("Installing Manim and Pi...", flush=True)
subprocess.run(["apt-get", "update", "-qq"], check=True)
subprocess.run(["apt-get", "install", "-y", "-q",
    "libcairo2-dev", "libpango1.0-dev", "ffmpeg", "ripgrep", "fd-find",
    "texlive-latex-base", "texlive-latex-extra", "texlive-fonts-recommended",
    "texlive-plain-generic", "dvisvgm"], check=True)
if shutil.which("fdfind") and not pathlib.Path("/usr/local/bin/fd").exists():
    pathlib.Path("/usr/local/bin/fd").symlink_to(shutil.which("fdfind"))
subprocess.run([sys.executable, "-m", "pip", "install", "-q",
    "numpy==1.26.4", "scipy==1.13.1", "manim", "nodeenv"], check=True)

base = pathlib.Path("/content")
node_dir = base / "node22"
pi_dir = base / "pi-runtime"
if not (node_dir / "bin" / "node").exists():
    subprocess.run([sys.executable, "-m", "nodeenv", "--node=22.19.0", "--prebuilt", str(node_dir)], check=True)
subprocess.run([str(node_dir / "bin" / "npm"), "install", "--prefix", str(pi_dir),
    "--no-audit", "--no-fund", "@earendil-works/pi-coding-agent@0.80.6"], check=True)

raw = "https://raw.githubusercontent.com/theabbie/ManimFlow/main"
runner = base / "manimflow_pi.py"
extension = base / "exa_direct.ts"
urllib.request.urlretrieve(raw + "/manimflow_pi.py", runner)
urllib.request.urlretrieve(raw + "/pi_extensions/exa_direct.ts", extension)

command = [sys.executable, str(runner), "--provider", "exa", "--prompt", {prompt!r},
    "--workspace", str(base / "manim_output"), "--output", str(base / "animation.mp4"),
    "--pi", str(pi_dir / "node_modules" / ".bin" / "pi"),
    "--exa-extension", str(extension), "--attempts", "6"]
subprocess.run(command, check=True, timeout=3600)
'''

info(f"Prompt: {prompt!r}")
session = get_session()
info(f"Session: {session}")

with tempfile.NamedTemporaryFile(mode="w", suffix=".py", delete=False, prefix="manimflow_") as file:
    file.write(worker)
    worker_path = file.name

try:
    info("Uploading autonomous Pi worker...")
    run(["colab", "upload", "-s", session, worker_path, "/content/worker.py"], capture=True)
    info("Running render; all useful Pi progress will be shown...")
    code = run(["colab", "exec", "-s", session, "--timeout", "5400", "-f", worker_path])
    if code:
        err(f"Worker failed with exit code {code}.")
        raise SystemExit(code)
    info(f"Downloading video to {output_path}")
    code = run(["colab", "download", "-s", session, "/content/animation.mp4", str(output_path)])
    if code:
        err("Video download failed.")
        raise SystemExit(code)
finally:
    info("Stopping Colab session...")
    run(["colab", "stop", "-s", session], capture=True)
    os.unlink(worker_path)

ok("Done!")
print(f"\n{output_path}")
