import time
threading.Thread(target=_keepalive, daemon=True).start()

for f in MANIM_OUTPUT.glob("*.py"): f.unlink()
for f in MANIM_OUTPUT.glob("*.md"): f.unlink()
git_dir = MANIM_OUTPUT / ".git"
if git_dir.exists(): shutil.rmtree(git_dir)

PROMPT = {repr(PROMPT)}
print(f"\\n=== Planning ===", flush=True)

payload = json.dumps({{"model":"manimator","messages":[
