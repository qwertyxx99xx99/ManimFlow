with tempfile.NamedTemporaryFile(mode='w', suffix='.py', delete=False, prefix='manimflow_') as f:
    f.write(WORKER)
    worker_path = f.name

try:
    info("Uploading worker...")
    run(["colab", "upload", "-s", session, worker_path, "/content/worker.py"], capture=True)

    info("Running render (10-30 min, all output shown)...")
    rc = run(["colab", "exec", "-s", session, "--timeout", "5400", "-f", worker_path])

    if rc != 0:
        err(f"Worker failed (exit {rc})")
        sys.exit(1)

    info(f"Downloading video → {out_path}")
    rc = run(["colab", "download", "-s", session, "/content/animation.mp4", str(out_path)])
    if rc != 0:
